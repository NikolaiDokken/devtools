{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "open-repo",
  "title": "Open Repo",
  "description": "Open a git repository in your preferred editor",
  "icon": "icon.png",
  "author": "nikolai",
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Open Repo",
      "description": "Search defined directories for git projects and open them in an editor of your choice",
      "mode": "view",
      "preferences": [
        {
          "name": "projectDirectories",
          "title": "Project Directories",
          "description": "Comma-separated list of directories to scan for git repositories (e.g. ~/Documents, ~/Work)",
          "type": "textfield",
          "required": true,
          "default": "~/Documents"
        },
        {
          "name": "editor1",
          "title": "Editor 1",
          "description": "First editor shown in the selection list",
          "type": "appPicker",
          "required": true
        },
        {
          "name": "editor2",
          "title": "Editor 2",
          "description": "Optional second editor",
          "type": "appPicker",
          "required": false
        },
        {
          "name": "editor3",
          "title": "Editor 3",
          "description": "Optional third editor",
          "type": "appPicker",
          "required": false
        },
        {
          "name": "editor4",
          "title": "Editor 4",
          "description": "Optional fourth editor",
          "type": "appPicker",
          "required": false
        },
        {
          "name": "editor5",
          "title": "Editor 5",
          "description": "Optional fifth editor",
          "type": "appPicker",
          "required": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.90.0"
  },
  "devDependencies": {
    "@raycast/utils": "^1.17.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
